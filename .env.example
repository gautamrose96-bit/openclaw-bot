# Telegram Bot Token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Key (get from https://console.groq.com/keys)
GROQ_API_KEY=your_groq_api_key_here

# Model to use (optional, defaults to llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# Max conversation context messages per chat (optional, default 20)
MAX_CONTEXT_MESSAGES=20

# Max tokens per response (optional, default 2048)
MAX_RESPONSE_TOKENS=2048

# System prompt (optional)
# SYSTEM_PROMPT=You are OpenClaw Bot, a helpful AI assistant powered by Groq.
