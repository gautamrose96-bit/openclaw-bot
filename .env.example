# ── Required ──
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── AI Providers (add as many as you want; more = better fallback) ──
# At least one is required. All are FREE tier.

# Groq (Primary) - https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini (Free) - https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Mistral (Free tier) - https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Cohere (Free) - https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# HuggingFace (Free) - https://huggingface.co/settings/tokens
HF_API_KEY=

# OpenRouter (Free models) - https://openrouter.ai/keys
OPENROUTER_API_KEY=

# DeepSeek ($5 free credits) - https://platform.deepseek.com
DEEPSEEK_API_KEY=

# Cerebras (fastest, free tier) - https://cloud.cerebras.ai
CEREBRAS_API_KEY=

# Qwen / Alibaba DashScope (free tier) - https://dashscope.aliyuncs.com
QWEN_API_KEY=

# Moonshot / Kimi (free credits) - https://platform.moonshot.cn
MOONSHOT_API_KEY=

# Zhipu AI GLM (glm-4-flash free) - https://open.bigmodel.cn
ZHIPU_API_KEY=

# SiliconFlow ($5 free credits) - https://siliconflow.cn
SILICONFLOW_API_KEY=

# Together AI ($5 free credits) - https://api.together.xyz
TOGETHER_API_KEY=

# Pollinations (keyless text AI) is always on as a last-resort fallback.
# Optionally set a key/referrer for higher limits - https://pollinations.ai
# POLLINATIONS_API_KEY=

# Web search: DuckDuckGo works with NO key (default). Google Custom Search is
# optional (100 free searches/day) - https://programmablesearchengine.google.com
# GOOGLE_API_KEY=
# GOOGLE_CSE_ID=

# ── Optional Settings ──
GROQ_MODEL=llama-3.1-8b-instant
MAX_CONTEXT_MESSAGES=20
MAX_RESPONSE_TOKENS=700
# Per-request timeout (s); slower models fall back to a faster one.
REQUEST_TIMEOUT=10
HEALTH_PORT=8080
# Optional: Telegram chat ID that receives crash/self-heal alerts.
# ADMIN_CHAT_ID=
# Per-user conversation memory (JSON file). Persists on a real host; wiped on
# ephemeral CI runners (e.g. GitHub Actions) at each restart.
MEMORY_PATH=data/memory.json
# SYSTEM_PROMPT=You are OpenClaw Bot, a helpful AI assistant.
